# Operator-laptop env for onboard.sh and offboard.sh.
# Copy to infra/.env and fill in. Never commit infra/.env (gitignored).
# Source it before running scripts:
#   set -a; . infra/.env; set +a
#   ./infra/bin/onboard.sh ...

# --- Cloudflare ----------------------------------------------------------
# Token scope: Zone:Edit, DNS:Edit, Zone Settings:Edit, Account:Read.
# Get it at https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# Find at https://dash.cloudflare.com (right sidebar of any zone page).
CLOUDFLARE_ACCOUNT_ID=

# --- VPS -----------------------------------------------------------------
# Public IPv4 of the Hetzner CX22.
VPS_IP=

# Marketing host for the operator. Hosts the Stripe webhook handler at
# /api/stripe-webhook. Update infra/Caddyfile if you change this.
VPS_HOST=careerstory.pro

# --- ImprovMX ------------------------------------------------------------
# Free tier API key from https://app.improvmx.com/api
IMPROVMX_API_KEY=

# --- Stripe --------------------------------------------------------------
# Live: sk_live_..., test: sk_test_...
STRIPE_SECRET_KEY=

# Recurring price object, $10/month, unit_amount=1000.
# Create at https://dashboard.stripe.com/products
STRIPE_PRICE_ID=

# --- UptimeRobot ---------------------------------------------------------
# Main API key from https://uptimerobot.com/dashboard#mySettings
UPTIMEROBOT_API_KEY=
